# ============================================================
# Trilho Kids — Instagram pipeline (.env OPCIONAL)
#
# As credenciais são lidas do config/env.php do projeto (putenv). Este .env
# serve só como OVERRIDE para testes locais e SOBREPÕE o env.php.
# Se você já usa o config/env.php, normalmente não precisa deste arquivo —
# no máximo defina TRILHO_ENV_PHP apontando para o env.php.
# NUNCA comite o .env.
# ============================================================

# Caminho para o config/env.php (se não estiver num dos locais padrão)
# TRILHO_ENV_PHP=/caminho/para/config/env.php


# --- Legendas via LLM (provider principal: NVIDIA; fallback: Anthropic) ---
# NVIDIA API (compatível com OpenAI). Provider PRINCIPAL das legendas.
NVIDIA_API_KEY=nvapi-...
# Opcionais (padrões abaixo):
# NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Anthropic — usado como FALLBACK se a NVIDIA falhar (ou como único, se NVIDIA vazio).
ANTHROPIC_API_KEY=sk-ant-...

# --- Instagram Graph API (publicação automática) ---
# ID da conta Instagram Business/Creator (Instagram User ID, não o @usuario).
# Como obter: Graph API Explorer -> GET /me/accounts -> pegar a Page ->
#   GET /{page-id}?fields=instagram_business_account
IG_USER_ID=1784xxxxxxxxxxx

# Token de acesso de LONGA duração (Page Access Token com permissão
# instagram_content_publish + instagram_basic + pages_read_engagement).
# Renove antes de expirar (~60 dias). Use um System User token para não expirar.
IG_ACCESS_TOKEN=EAAG...

# Versão da Graph API
IG_API_VERSION=v21.0

# --- Hospedagem pública dos assets renderizados ---
# A Graph API BAIXA a imagem de um URL público. O pipeline renderiza os PNGs
# localmente e precisa subi-los para um host público antes de publicar.
# Endpoint PHP no cPanel (veja api/ig_upload.php). Deixe vazio para modo
# --dry-run (só gera os PNGs em ./out, sem publicar).
IG_UPLOAD_URL=https://cafecomhomensdedeus.com.br/trilhokids/api/ig_upload.php
# Segredo compartilhado que protege o ig_upload.php (defina o MESMO valor lá).
IG_UPLOAD_TOKEN=troque-por-um-segredo-forte

# --- Opcional ---
# Modelo Claude para as legendas (padrão: claude-opus-4-8)
CAPTION_MODEL=claude-opus-4-8
